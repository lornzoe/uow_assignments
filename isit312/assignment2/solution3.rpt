0: jdbc:hive2://localhost:10000> DROP TABLE IF EXISTS employees;
0: jdbc:hive2://localhost:10000> 
0: jdbc:hive2://localhost:10000> -- 1. Creates an internal relational table to store information about the emp loyees,
0: jdbc:hive2://localhost:10000> -- the projects they are assigned to (project name and percentage of involvem ent)
0: jdbc:hive2://localhost:10000> -- and their programming skills.
0: jdbc:hive2://localhost:10000> 
0: jdbc:hive2://localhost:10000> CREATE TABLE IF NOT EXISTS employees (
. . . . . . . . . . . . . . . .>     emp_number STRING,
. . . . . . . . . . . . . . . .>     full_name STRING,
. . . . . . . . . . . . . . . .>     projects MAP<STRING, INT>,
. . . . . . . . . . . . . . . .>     skills ARRAY<STRING>
. . . . . . . . . . . . . . . .> )
. . . . . . . . . . . . . . . .> ROW FORMAT DELIMITED
. . . . . . . . . . . . . . . .> FIELDS TERMINATED BY '|'
. . . . . . . . . . . . . . . .> COLLECTION ITEMS TERMINATED BY ','
. . . . . . . . . . . . . . . .> MAP KEYS TERMINATED BY ':'
. . . . . . . . . . . . . . . .> STORED AS TEXTFILE;
0: jdbc:hive2://localhost:10000> 
0: jdbc:hive2://localhost:10000> -- 2. Include into the script INSERT statements that load sample data into th e table. (at least 5)
0: jdbc:hive2://localhost:10000> 
0: jdbc:hive2://localhost:10000> -- Condition 1: Two employees must participate in few projects and must know  few programming languages
0: jdbc:hive2://localhost:10000> INSERT INTO employees SELECT '1', 'Employee 1', map('Project1', 30, 'Project2 ', 25, 'Project3', 100), array('Java', 'C', 'C++');
0: jdbc:hive2://localhost:10000> INSERT INTO employees SELECT '2', 'Employee 2', map('Project4', 50, 'Project5 ', 50), array('Python', 'Rust');
0: jdbc:hive2://localhost:10000> 
0: jdbc:hive2://localhost:10000> -- Condition 2: One employee must participate in few projects and must not kn ow any programming languages
0: jdbc:hive2://localhost:10000> INSERT INTO employees SELECT '3', 'Employee 3', map('Project1', 70, 'Project2 ', 75), IF(false, array('dummy'), NULL);
0: jdbc:hive2://localhost:10000> 
0: jdbc:hive2://localhost:10000> -- Condition 3: One employee must know few programming languages and must not  participate in any projects.
0: jdbc:hive2://localhost:10000> INSERT INTO employees SELECT '4', 'Employee 4', IF(false, map('dummy', 1), NU LL), array('C', 'Rust');
0: jdbc:hive2://localhost:10000> 
0: jdbc:hive2://localhost:10000> -- Condition 4: One employee must not know programming languages and must not  participate in the projects.
0: jdbc:hive2://localhost:10000> INSERT INTO employees SELECT '5', 'Employee 5', IF(false, map('dummy', 1), NU LL), IF(false, array('dummy'), NULL);
0: jdbc:hive2://localhost:10000> 
0: jdbc:hive2://localhost:10000> -- 3. SELECT statement to list the contents of the table
0: jdbc:hive2://localhost:10000> SELECT * FROM employees;
+-----------------------+----------------------+-----------------------------------------------+---------------------+--+
| employees.emp_number  | employees.full_name  |              employees.projects               |  employees.skills   |
+-----------------------+----------------------+-----------------------------------------------+---------------------+--+
| 1                     | Employee 1           | {"Project1":30,"Project2":25,"Project3":100}  | ["Java","C","C++"]  |
| 2                     | Employee 2           | {"Project4":50,"Project5":50}                 | ["Python","Rust"]   |
| 3                     | Employee 3           | {"Project1":70,"Project2":75}                 | NULL                |
| 4                     | Employee 4           | NULL                                          | ["C","Rust"]        |
| 5                     | Employee 5           | NULL                                          | NULL                |
+-----------------------+----------------------+-----------------------------------------------+---------------------+--+
